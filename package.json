    "@supabase/supabase-js": "^2.105.4",
    "@t3-oss/env-core": "^0.13.11",
    "base64-arraybuffer": "^1.0.2",
    "es-toolkit": "^1.46.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
