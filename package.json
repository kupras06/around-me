    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --write .",
    "check": "biome check .",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > ./lib/database.types.ts",
    "check:fix": "biome check --write ."
  },
