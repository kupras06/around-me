{
  "expo": {
    "name": "Around Me",
    "slug": "around-me",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo/icon-mark-1024.png",
    "scheme": "aroundme",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spiderx.aroundme"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/logo/icon-mark-1024.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/logo/icon-mark-192.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.spiderx.aroundme"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/icon-mark-192.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/SpaceMono-Regular.ttf"]
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/logo/logo-full@2x.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
